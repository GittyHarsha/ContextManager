{
	"compilerOptions": {
		"module": "Node16",
		"target": "ES2024",
		"lib": ["ES2024"],
		"sourceMap": true,
		"rootDir": "src",
		"outDir": "out",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react",
		"jsxFactory": "vscpp",
		"jsxFragmentFactory": "vscppf"
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "out", "src/tools.old.ts", "src/chatParticipant.old.ts"]
}
